# Copy to `.env` in the project root (gitignored). `config.LoadConfig()` runs `godotenv.Load()`.

# Gin: use `debug` for verbose Gin logs.
# GIN_MODE=debug

# HTTP listen address (host:port or :port).
# SERVER_ADDR=:8080

# Max successful requests per user per window (integer > 0). Default 5.
# RATE_LIMIT_MAX_REQUESTS=5

# Sliding window length (Go duration: 1m, 60s, …). Default 1m.
# RATE_LIMIT_WINDOW=1m
